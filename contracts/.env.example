# Wallet that deploys the contract (needs MATIC for gas)
DEPLOYER_PRIVATE_KEY=0x...

# The backend server's signing wallet address (NOT the private key — just the address)
# Server wallet private key goes in server/.env as SERVER_SIGNING_KEY
SERVER_WALLET_ADDRESS=0x...

# Your house wallet address — receives 15% rake
HOUSE_WALLET_ADDRESS=0x...

# PolygonScan API key for contract verification (get from polygonscan.com)
POLYGONSCAN_API_KEY=...

# RPC endpoints (optional — defaults work fine)
POLYGON_RPC=https://polygon-rpc.com
AMOY_RPC=https://rpc-amoy.polygon.technology
