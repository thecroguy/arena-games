# Wallet that deploys the contract (needs ~1 MATIC for gas — get free at faucet.polygon.technology)
DEPLOYER_PRIVATE_KEY=0x...

# The backend server's signing wallet PUBLIC ADDRESS (not the private key — server never spends gas)
# The matching private key goes in server/.env as SERVER_SIGNING_KEY
SERVER_WALLET_ADDRESS=0x...

# Your house wallet address — receives 15% rake from every game
HOUSE_WALLET_ADDRESS=0x...

# PolygonScan API key for contract verification — optional, skip for now
POLYGONSCAN_API_KEY=

# RPC endpoints (optional — defaults work fine)
POLYGON_RPC=https://polygon-rpc.com
AMOY_RPC=https://rpc-amoy.polygon.technology

# Set these after running deploy:amoy — used by the mint script
MOCK_USDT_AMOY=0x...   # printed by deploy:amoy
MINT_TO=0x...           # player wallet to fund with test USDT
MINT_AMOUNT=1000        # how much test USDT to mint
