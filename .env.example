# ── Arena Games Frontend ─────────────────────────────────────────────────────
# All vars must start with VITE_ to be exposed to the browser

# Your Render.com backend URL (e.g. https://arena-games-server.onrender.com)
VITE_SOCKET_URL=http://localhost:3001

# Supabase — get from supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# WalletConnect Project ID — get free one at cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your-project-id-here
